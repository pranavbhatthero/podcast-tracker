# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Override the model used for extraction (optional — sensible defaults are set)
# Anthropic examples: claude-haiku-4-5-20251001  claude-sonnet-5  claude-opus-4-8
# OpenAI examples:    gpt-4o-mini  gpt-4o  gpt-4-turbo
# LLM_MODEL=claude-haiku-4-5-20251001

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Standard Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (set LLM_PROVIDER=openai above to use these) ──────────────────────
# Standard OpenAI key — get one at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Optional: point at any OpenAI-compatible endpoint (Ollama, Together, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Advanced: Salesforce / AWS Bedrock gateway ────────────────────────────────
# Only needed if routing through a corporate Bedrock proxy
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BEDROCK_BASE_URL=https://your-gateway.example.com/bedrock
# NODE_EXTRA_CA_CERTS=/path/to/corp-ca-bundle.pem

# ── Email digest (optional — leave blank to disable) ─────────────────────────
# SMTP credentials for watcher.py email notifications
# NOTIFY_EMAIL=you@example.com
# NOTIFY_FROM_EMAIL=sender@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=sender@gmail.com
# SMTP_PASSWORD=your-app-password
